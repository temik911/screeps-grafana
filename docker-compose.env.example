# SCREEPS_SHARD: one shard, or a comma list for multi-shard (e.g. shard2,shard3). Metrics are
# namespaced as stats.gauges.<shard>.* (dashboard templates on $shard).
SCREEPS_SHARD=shard3
# SCREEPS_TOKEN: a single token (reused for every shard) or a comma list aligned with SCREEPS_SHARD.
# NOTE: the 360 req/h memory-segment limit is SHARED across an account's tokens — extra tokens do NOT
# add budget, so a single token is fine. The poller spaces requests at SCREEPS_POLL_BASE_MS × shardCount
# (default base 12s → 300 req/h total, under the 360 cap) regardless of shard or token count.
SCREEPS_TOKEN=your-auth-token-from-screeps.com/a/#!/account/auth-tokens
SCREEPS_HOST=https://screeps.com
SCREEPS_SEGMENT=15
# Optional: base poll interval in ms (per request slot). Default 12000. Total req/h = 3600000/base.
# SCREEPS_POLL_BASE_MS=12000
