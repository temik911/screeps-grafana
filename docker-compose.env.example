# SCREEPS_SHARD: one shard, or a comma list for multi-shard (e.g. shard2,shard3). Metrics are
# namespaced as stats.gauges.<shard>.* (dashboard templates on $shard).
SCREEPS_SHARD=shard3
# SCREEPS_TOKEN: one token, or a comma list ALIGNED with SCREEPS_SHARD (token[i] -> shard[i]).
# The 360 req/h segment rate limit is PER TOKEN, so give each shard its own token to poll at the full
# 10s rate. A single shared token across N shards is allowed but scales the interval to 10s × N.
# Multi-shard example:  SCREEPS_SHARD=shard2,shard3   SCREEPS_TOKEN=token-for-shard2,token-for-shard3
SCREEPS_TOKEN=your-auth-token-from-screeps.com/a/#!/account/auth-tokens
SCREEPS_HOST=https://screeps.com
SCREEPS_SEGMENT=15
