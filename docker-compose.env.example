SCREEPS_TOKEN=your-auth-token-from-screeps.com/a/#!/account/auth-tokens
SCREEPS_HOST=https://screeps.com
# One shard, or a comma-separated list for multi-shard (e.g. shard2,shard3). Each shard is polled on
# its own interval (10s × shard count, to stay under the 360 req/h per-token segment rate limit) and
# its metrics are namespaced as stats.gauges.<shard>.* (dashboard templates on $shard).
SCREEPS_SHARD=shard3
SCREEPS_SEGMENT=15
