{
  "dashboard": {
    "uid": "screeps-overview",
    "title": "Screeps Colony Overview",
    "tags": ["screeps"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": {"from": "now-1h", "to": "now"},
    "graphTooltip": 1,
    "editable": true,
    "fiscalYearStartMonth": 0,
    "annotations": {"list": []},
    "templating": {"list": []},
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "CPU / tick",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "datasource": "localGraphite",
        "targets": [
          {"target": "stats.gauges.cpu.used", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 2,
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 15},
                {"color": "red", "value": 20}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "textMode": "auto"
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "CPU limit",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "datasource": "localGraphite",
        "targets": [
          {"target": "stats.gauges.cpu.limit", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 0,
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [{"color": "blue", "value": null}]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "CPU bucket",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "datasource": "localGraphite",
        "targets": [
          {"target": "stats.gauges.cpu.bucket", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 0,
            "unit": "none",
            "min": 0,
            "max": 10000,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 3000},
                {"color": "green", "value": 8000}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "textMode": "auto"
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "GCL level",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "datasource": "localGraphite",
        "targets": [
          {"target": "stats.gauges.gcl.level", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 0,
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [{"color": "purple", "value": null}]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "textMode": "auto"
        }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "CPU used vs limit",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": "localGraphite",
        "targets": [
          {"target": "alias(stats.gauges.cpu.used, 'used')", "refId": "A"},
          {"target": "alias(stats.gauges.cpu.limit, 'limit')", "refId": "B"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "limit"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            }
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "CPU bucket",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "datasource": "localGraphite",
        "targets": [
          {"target": "stats.gauges.cpu.bucket", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "max": 10000,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 25,
              "spanNulls": true,
              "showPoints": "never",
              "gradientMode": "scheme"
            },
            "color": {"mode": "continuous-RdYlGr"}
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": false, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "single", "sort": "none"}
        }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "CPU per process",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.processes.cpu.*, 4)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 30,
              "stacking": {"mode": "normal", "group": "A"},
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Room — energy available / capacity",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.rooms.*.energy, 3)", "refId": "A"},
          {"target": "aliasSub(aliasByNode(stats.gauges.rooms.*.energyCap, 3), '$', ' (cap)')", "refId": "B"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": ".*\\(cap\\)$"},
              "properties": [
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            }
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "Room — storage energy",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.rooms.*.storageEnergy, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 20,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 10,
        "type": "timeseries",
        "title": "Room — creeps vs hostiles",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasSub(aliasByNode(stats.gauges.rooms.*.creeps, 3), '$', ' creeps')", "refId": "A"},
          {"target": "aliasSub(aliasByNode(stats.gauges.rooms.*.hostiles, 3), '$', ' hostiles')", "refId": "B"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": ".*hostiles$"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
                {"id": "custom.fillOpacity", "value": 40}
              ]
            }
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 11,
        "type": "timeseries",
        "title": "Room — spawn queue depth & build sites",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasSub(aliasByNode(stats.gauges.rooms.*.spawnQueueDepth, 3), '$', ' queue')", "refId": "A"},
          {"target": "aliasSub(aliasByNode(stats.gauges.rooms.*.sites, 3), '$', ' sites')", "refId": "B"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 12,
        "type": "timeseries",
        "title": "Throughput — storage rate (e/tick)",
        "description": "Net energy flow into storage, averaged over the statsHistory window (~600 ticks). Negative = drawing down.",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.rooms.*.storageRate, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never",
              "axisSoftMin": 0
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 0}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 13,
        "type": "timeseries",
        "title": "Throughput — upgrade rate (pt/tick)",
        "description": "Controller progress per tick, averaged over statsHistory window. RCL-8 cap is 15 pt/t.",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.rooms.*.upgradeRate, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 20,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 14,
        "type": "timeseries",
        "title": "Throughput — build rate (pt/tick)",
        "description": "Construction progress per tick. Drops negative when a site completes (its progress disappears from the sum) — real signal, not a bug.",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 44},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.rooms.*.buildRate, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never",
              "axisSoftMin": 0
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "blue", "value": 0}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 15,
        "type": "timeseries",
        "title": "Construction work outstanding",
        "description": "Sum of in-flight construction site progress, per room. Goes up when new sites are placed, down as builders work, jumps to 0 when the last site completes.",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 44},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.rooms.*.sitesProgress, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 20,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 16,
        "type": "timeseries",
        "title": "Remote — reservation countdown",
        "description": "controller.reservation.ticksToEnd per remote. Below 1500 ReserverProcess spawns a replacement; below 0 means we lost the reservation (source caps drop to 1500e and decay rate doubles for containers).",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 52},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.remotes.*.reservedUntil, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "max": 5000,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 1500},
                {"color": "green", "value": 3000}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 17,
        "type": "timeseries",
        "title": "Remote — most damaged infra HP %",
        "description": "Lowest HP percentage across ALL our roads + containers in the remote (0-100). Thresholds match the repair policy: RemoteRoomProcess flips needsRepair when this drops below 75%; RemoteRepairProcess targets 90% on each structure. \"No data\" = remote not visible this tick (we don't have a creep there to enumerate structures).",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 52},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.remotes.*.minInfraHpPct, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 0,
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 75},
                {"color": "green", "value": 90}
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 18,
        "type": "timeseries",
        "title": "Remote — creep pool per role",
        "description": "Live creep counts per role per remote. reserver should be 1 most of the time; miner = containers built; vision = 0 once reserver/miner provide visibility; repairer = 1 while needsRepair flag is set.",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 60},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.reserverCount, 3), '$', ' reserver')", "refId": "A"},
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.minerCount, 3), '$', ' miner')", "refId": "B"},
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.visionCount, 3), '$', ' vision')", "refId": "C"},
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.repairerCount, 3), '$', ' repair')", "refId": "D"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        }
      },
      {
        "id": 19,
        "type": "timeseries",
        "title": "Remote — container energy queue (waiting for haulers)",
        "description": "Sum of energy sitting in remote source containers per remote. Steady oscillation between 0 and ~1600 is normal (miner deposits, hauler drains). Sustained climb to ~2000 (cap) means the hauler pool is undersized for this remote's travelTicks.",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 68},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.remotes.*.containerEnergyTotal, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 20,
              "spanNulls": true,
              "showPoints": "never"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 20,
        "type": "timeseries",
        "title": "Remote — build progress (containers + roads done / planned)",
        "description": "Counts of sources whose container is built and whose roads are fully laid, per remote. Both should reach `sourceCount` shortly after enableRemote; until they do RemoteSourceProcess holds off spawning miners and HaulerScheduler excludes the container from the pool.",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 68},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.sourceCount, 3), '$', ' planned')", "refId": "A"},
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.containersBuilt, 3), '$', ' containers')", "refId": "B"},
          {"target": "aliasSub(aliasByNode(stats.gauges.remotes.*.roadsBuilt, 3), '$', ' roads')", "refId": "C"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true,
              "showPoints": "never"
            },
            "overrides": [
              {
                "matcher": {"id": "byRegexp", "options": ".*planned$"},
                "properties": [
                  {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                  {"id": "custom.fillOpacity", "value": 0}
                ]
              }
            ]
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      },
      {
        "id": 21,
        "type": "timeseries",
        "title": "Remote — needsRepair flag",
        "description": "Binary 0/1 per remote — 1 means RemoteRoomProcess saw a road/container below 75% HP. RemoteRepairProcess spawns a 200e repairer (1W/1C/1M) while the flag is set; flag drops when everything's back above 75%.",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 76},
        "datasource": "localGraphite",
        "targets": [
          {"target": "aliasByNode(stats.gauges.remotes.*.needsRepair, 3)", "refId": "A"}
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 0,
            "min": 0,
            "max": 1,
            "custom": {
              "drawStyle": "bars",
              "lineWidth": 1,
              "fillOpacity": 80,
              "spanNulls": false,
              "showPoints": "never"
            },
            "color": {"mode": "fixed", "fixedColor": "orange"}
          },
          "overrides": []
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi", "sort": "none"}
        }
      }
    ]
  },
  "overwrite": true,
  "folderUid": ""
}
